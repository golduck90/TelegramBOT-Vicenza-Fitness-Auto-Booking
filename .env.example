# Vicenza Fitness Bot — Configurazione
# Copia questo file come .env e compila i campi

# Token del bot Telegram (obbligatorio — ottienilo da @BotFather)
TELEGRAM_BOT_TOKEN="il_tuo_token_qui"

# AppToken WellTeam (obbligatorio — token company-level della palestra)
# Si trova nell'app WellTeam o chiedi al gestore della palestra
WELLTEAM_APP_TOKEN="il_tuo_app_token_qui"

# URL del server WellTeam (di solito non serve cambiarlo)
# WELLTEAM_IYES_URL="http://185.103.80.254:65432/"

# Chiave Fernet per crittografia password (opzionale — auto-generata al primo avvio)
# FERNET_KEY=""

# Livello di log (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL="INFO"

# Intervallo auto-booking in minuti (default: 30)
# AUTOBOOK_CHECK_INTERVAL="30"

# ID admin Telegram (opzionale, separati da virgola)
# ADMIN_IDS=""
