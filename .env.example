# Vicenza Fitness Bot — Configurazione
#
# Per i token WellTeam, vedi docs/TOKENS.md
# ===============================================

# Obbligatorio: token del bot Telegram (da @BotFather)
TELEGRAM_BOT_TOKEN=

# Obbligatorio: company-level token WellTeam
# Vedi docs/TOKENS.md per il valore
WELLTEAM_APP_TOKEN=

# Opzionale: livello di log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
